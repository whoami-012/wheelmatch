# Local development only. Replace placeholders in a private .env file.
POSTGRES_USER=wheelmatch
POSTGRES_PASSWORD=replace-with-local-only-password
POSTGRES_DB=wheelmatch
POSTGRES_PORT=55432
REDIS_PASSWORD=replace-with-local-only-password
REDIS_PORT=56379
LOCALSTACK_PORT=54566
API_PORT=58000

WHEELMATCH_ENVIRONMENT=local
WHEELMATCH_LOG_LEVEL=INFO
WHEELMATCH_DATABASE_URL=postgresql+asyncpg://wheelmatch:replace-with-local-only-password@db:5432/wheelmatch
WHEELMATCH_REDIS_URL=redis://:replace-with-local-only-password@redis:6379/0
WHEELMATCH_AWS_REGION=us-east-1
WHEELMATCH_AWS_ENDPOINT_URL=http://localstack:4566
WHEELMATCH_SQS_EVENTS_QUEUE_URL=http://localstack:4566/000000000000/wheelmatch-events
WHEELMATCH_S3_MEDIA_BUCKET=wheelmatch-media-local
WHEELMATCH_SENTRY_DSN=

# Dummy LocalStack credentials; never reuse outside local development.
AWS_ACCESS_KEY_ID=localstack
AWS_SECRET_ACCESS_KEY=localstack
